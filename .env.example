# ────────────────────────────────────────────────────────────────────────────
# Pulse Bots — environment variables
# Copy to `.env` for local dev, or set them in Coolify for production.
# ────────────────────────────────────────────────────────────────────────────

# ── General ────────────────────────────────────────────────────────────────
APP_ENV=development                       # development | production
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
BOT_TYPE=news                             # news | sports | cars | prices

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pulse:pulse@localhost:5432/pulse_bots
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── MinIO (S3-compatible) ──────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000      # https URL in production
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pulse-bots
MINIO_REGION=us-east-1
MINIO_PUBLIC_DOMAIN=https://cdn.example.com   # public base URL serving the bucket
MINIO_USE_SSL=false

# ── Telegram userbot (Telethon, MTProto) ───────────────────────────────────
# Get from https://my.telegram.org
TELEGRAM_API_ID= 919900
TELEGRAM_API_HASH=5910eb1e5f7581c0a3e24aa281f0e643
# Run `python scripts/login_telethon.py` once locally to create this string.
# Use a DEDICATED account (ToS / ban risk).
TELETHON_SESSION=

# ── Telegram bot (aiogram, Bot API) ────────────────────────────────────────
BOT_TOKEN= 8588765665:AAF7y1iNadN8dSz5nvLBL98DSDLcLhqlkBk
# Numeric chat id of the destination channel (e.g. -1001234567890).
# The bot must be an admin in this channel.
DESTINATION_CHANNEL_ID= -1003925325790
# Comma-separated list of Telegram user ids that may use admin commands.
ADMIN_IDS=396777364

# ── LLM (Avalai — OpenAI-compatible gateway in front of Gemini) ────────────
# Get your key from https://avalai.ir/
AVALAI_API_KEY= aa-g7NSUZ1mKkyGtJjCCgjwl0bmKWcmusGco2vedA7mLfSsx5W3
AVALAI_BASE_URL=https://api.avalai.org/v1
LLM_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=30

# ── Pipeline tuning ────────────────────────────────────────────────────────
MIN_PUBLISH_IMPORTANCE=2                  # 1–5; only publish articles >= this
SUMMARY_LANGUAGE=fa                       # ISO code for the rewritten summary
PUBLISH_RATE_PER_SECOND=1                 # Telegram channel limit
CATCHUP_INTERVAL_MINUTES=15               # catch-up sweep for offline gaps
CATCHUP_LOOKBACK_MESSAGES=50              # max messages per source on catch-up
